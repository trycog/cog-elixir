{
  "name": "cog-elixir",
  "extensions": [".ex", ".exs"],
  "args": ["{file}", "--output", "{output}"],
  "build": "mix escript.build && mkdir -p bin && cp cog_elixir bin/cog-elixir",
  "debugger": {
    "type": "dap",
    "adapter": {
      "command": "elixir_ls",
      "args": ["--stdio"],
      "transport": "stdio"
    },
    "launch_args": "{\"type\":\"mix_task\",\"task\":\"run\",\"taskArgs\":[\"{program}\"],\"projectDir\":\"{cwd}\",\"requireFiles\":[\"test/**/test_helper.exs\",\"test/**/*_test.exs\"]}",
    "boundary_markers": [":erlang.apply", ":elixir_compiler", ":elixir_dispatch"]
  }
}
