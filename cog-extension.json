{
  "name": "cog-elixir",
  "version": "0.1.0",
  "extensions": [".ex", ".exs", ".eex", ".heex"],
  "language_names": ["elixir"],
  "args": ["--output", "{output}", "{files}"],
  "build": "mix local.hex --force && mix deps.get && mix escript.build && mkdir -p bin && cp cog_elixir bin/cog-elixir",
  "debugger": {
    "type": "dap",
    "adapter": {
      "command": "elixir_ls",
      "args": ["--stdio"],
      "transport": "stdio"
    },
    "launch_args": "{\"type\":\"mix_task\",\"projectDir\":\"{cwd}\",\"requireFiles\":[\"lib/**/*.ex\"],\"exitAfterTaskReturns\":false}",
    "program_field": "task",
    "args_field": "taskArgs",
    "args_first_is_program": true,
    "skip_entry_stop": true,
    "boundary_markers": [":erlang.apply", ":elixir_compiler", ":elixir_dispatch"]
  }
}
